<?xml version="1.0" encoding="utf-8"?>
<device schemaVersion="1.1" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance">
  <name>ClusterDimTest</name>
  <version>1.0</version>
  <description>Test device for an array of clusters using dim/dimIncrement</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <peripherals>
    <peripheral>
      <name>PERIPH0</name>
      <description>Peripheral with a two-element cluster array</description>
      <baseAddress>0x40000000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <!--
          CH%s is an array of two channel clusters, each 0x20 bytes apart.
          CH0 starts at 0x10, CH1 starts at 0x30.
          Each cluster carries a CTRL (rw) and a STATUS (ro) register.
          The cluster-level <access>read-write</access> is inherited by CTRL;
          STATUS overrides it to read-only.
        -->
        <cluster>
          <dim>2</dim>
          <dimIncrement>0x20</dimIncrement>
          <name>CH%s</name>
          <description>Channel cluster</description>
          <addressOffset>0x10</addressOffset>
          <access>read-write</access>
          <register>
            <name>CTRL</name>
            <description>Channel control register (inherits read-write from cluster)</description>
            <addressOffset>0x0</addressOffset>
            <size>32</size>
          </register>
          <register>
            <name>STATUS</name>
            <description>Channel status register (overrides to read-only)</description>
            <addressOffset>0x4</addressOffset>
            <size>32</size>
            <access>read-only</access>
          </register>
        </cluster>
      </registers>
    </peripheral>
  </peripherals>
</device>
