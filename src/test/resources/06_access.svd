<?xml version="1.0" encoding="utf-8"?>
<device schemaVersion="1.1" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance">
  <name>AccessTest</name>
  <version>1.0</version>
  <description>Test device for access tag at device, register and field levels</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <access>read-write</access>
  <peripherals>
    <peripheral>
      <name>PERIPH0</name>
      <description>Test peripheral</description>
      <baseAddress>0x40000000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>REG_RO</name>
          <description>Read-only register</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <fields>
            <field>
              <name>FIELD0</name>
              <description>A read-only field</description>
              <lsb>0</lsb>
              <msb>7</msb>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>REG_WO</name>
          <description>Write-only register</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <fields>
            <field>
              <name>FIELD0</name>
              <description>A write-only field</description>
              <lsb>0</lsb>
              <msb>7</msb>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>REG_RW</name>
          <description>Read-write register (inherited from device)</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
