<?xml version="1.0" encoding="utf-8"?>
<device schemaVersion="1.1" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance">
  <name>ReadActionTest</name>
  <version>1.0</version>
  <description>Test device for the readAction tag in registers</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <peripherals>
    <peripheral>
      <name>UART</name>
      <description>UART peripheral</description>
      <baseAddress>0x40002000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>DR</name>
          <description>Data register - reading clears the data</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <readAction>clear</readAction>
        </register>
        <register>
          <name>ISR</name>
          <description>Interrupt status - reading triggers external modification</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <readAction>modifyExternal</readAction>
        </register>
        <register>
          <name>SR</name>
          <description>Status register - reading sets the register</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <readAction>set</readAction>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
