<?xml version="1.0" encoding="utf-8"?>
<device schemaVersion="1.1" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance">
  <name>DataTypeTest</name>
  <version>1.0</version>
  <description>Test device for the dataType tag specifying the C type of a register</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <peripherals>
    <peripheral>
      <name>SENSOR</name>
      <description>Sensor peripheral</description>
      <baseAddress>0x40030000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>TEMP</name>
          <description>Temperature reading as a signed 32-bit integer</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <dataType>int32_t</dataType>
        </register>
        <register>
          <name>ACCEL</name>
          <description>Acceleration reading as a signed 16-bit integer</description>
          <addressOffset>0x4</addressOffset>
          <size>16</size>
          <dataType>int16_t</dataType>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
