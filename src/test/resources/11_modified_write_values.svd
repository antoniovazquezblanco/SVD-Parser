<?xml version="1.0" encoding="utf-8"?>
<device schemaVersion="1.1" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance">
  <name>ModifiedWriteValuesTest</name>
  <version>1.0</version>
  <description>Test device for the modifiedWriteValues tag in registers</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <peripherals>
    <peripheral>
      <name>GPIO</name>
      <description>GPIO peripheral</description>
      <baseAddress>0x50000000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>OUTSET</name>
          <description>Set individual output bits - writing 1 sets the bit</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <modifiedWriteValues>oneToSet</modifiedWriteValues>
        </register>
        <register>
          <name>OUTCLR</name>
          <description>Clear individual output bits - writing 1 clears the bit</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <modifiedWriteValues>oneToClear</modifiedWriteValues>
        </register>
        <register>
          <name>OUTTGL</name>
          <description>Toggle individual output bits - writing 1 toggles the bit</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <modifiedWriteValues>oneToToggle</modifiedWriteValues>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
